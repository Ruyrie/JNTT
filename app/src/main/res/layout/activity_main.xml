<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Fragment 容器（内容延伸到底部，让玻璃栏浮在上面） -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="90dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- 液态玻璃底部导航栏 -->
    <FrameLayout
        android:id="@+id/glassNavContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingBottom="16dp"
        android:paddingTop="6dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 玻璃栏：背景模糊 + 半透明白叠加 + 描边 -->
        <com.example.jntt.view.RoundedClipFrame
            android:id="@+id/glassNavClip"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:elevation="0dp"
            app:cornerRadius="34dp">

            <!-- 实时模糊背后的内容 -->
            <com.example.jntt.view.BlurBehindView
                android:id="@+id/navBlur"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- 半透明白色 + 描边覆盖层（玻璃质感） -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_glass_nav" />

            <!-- 滑动液态药丸：单独的圆角剪裁层 + 内部模糊 -->
            <com.example.jntt.view.RoundedClipFrame
                android:id="@+id/glassPill"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="6dp"
                app:cornerRadius="26dp">

                <com.example.jntt.view.BlurBehindView
                    android:id="@+id/pillBlur"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_glass_pill" />
            </com.example.jntt.view.RoundedClipFrame>

            <!-- 三个 tab -->
            <LinearLayout
                android:id="@+id/glassTabBar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:weightSum="3">

                <LinearLayout
                    android:id="@+id/tabHeadline"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/ripple_transparent">

                    <ImageView
                        android:id="@+id/iconHeadline"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_nav_headline"
                        app:tint="#2F80ED" />

                    <TextView
                        android:id="@+id/labelHeadline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="头条"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#2F80ED"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tabMall"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/ripple_transparent">

                    <ImageView
                        android:id="@+id/iconMall"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_nav_mall"
                        app:tint="#1F1F1F" />

                    <TextView
                        android:id="@+id/labelMall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="商城"
                        android:textSize="11sp"
                        android:textColor="#1F1F1F"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tabMine"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/ripple_transparent">

                    <ImageView
                        android:id="@+id/iconMine"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_nav_mine"
                        app:tint="#1F1F1F" />

                    <TextView
                        android:id="@+id/labelMine"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="我的"
                        android:textSize="11sp"
                        android:textColor="#1F1F1F"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>
        </com.example.jntt.view.RoundedClipFrame>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
