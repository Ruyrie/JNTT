<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 状态卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F04142"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvDetailStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:text="待支付" />

            <TextView
                android:id="@+id/tvDetailCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#FFCCCC"
                android:layout_marginTop="4dp"
                android:text="" />
        </LinearLayout>

        <!-- 商品信息 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="商品信息"
                android:textSize="13sp"
                android:textColor="#8A8A8A"
                android:paddingHorizontal="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="8dp" />

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="#E5E5EA"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/ivDetailProduct"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_product_placeholder"
                    android:background="#F5F5F5"
                    android:scaleType="centerInside"
                    android:layout_marginEnd="14dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvDetailName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textColor="#1F1F1F"
                        android:maxLines="2"
                        android:text="商品名" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/tvDetailPrice"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#F04142"
                            android:text="¥0.00" />

                        <TextView
                            android:id="@+id/tvDetailQty"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#8A8A8A"
                            android:text="x1" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 订单信息 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:layout_marginBottom="12dp"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="订单信息"
                android:textSize="13sp"
                android:textColor="#8A8A8A"
                android:paddingHorizontal="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="8dp" />

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="#E5E5EA"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="46dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingHorizontal="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="订单编号"
                    android:textSize="14sp" android:textColor="#1F1F1F"/>
                <TextView android:id="@+id/tvDetailOrderId"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="13sp" android:textColor="#8A8A8A" android:text="—"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="#E5E5EA" android:layout_marginStart="16dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="46dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingHorizontal="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="下单时间"
                    android:textSize="14sp" android:textColor="#1F1F1F"/>
                <TextView android:id="@+id/tvDetailTime"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="13sp" android:textColor="#8A8A8A" android:text="—"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="#E5E5EA" android:layout_marginStart="16dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="46dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingHorizontal="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="实付金额"
                    android:textSize="14sp" android:textColor="#1F1F1F"/>
                <TextView android:id="@+id/tvDetailTotal"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="15sp" android:textStyle="bold"
                    android:textColor="#F04142" android:text="¥0.00"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 操作按钮（待支付才显示） -->
        <LinearLayout
            android:id="@+id/layoutDetailActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:visibility="gone">

            <Button
                android:id="@+id/btnDetailCancel"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="取消订单"
                android:textColor="#1F1F1F"
                android:textSize="15sp"
                android:background="@drawable/bg_auth_input"
                android:stateListAnimator="@null"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btnDetailPay"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="立即支付"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/bg_auth_button"
                android:stateListAnimator="@null" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
