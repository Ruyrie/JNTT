<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F7"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 顶部标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="@color/white"
            android:layout_marginBottom="20dp">
            <TextView
                android:id="@+id/tvBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="‹"
                android:textSize="28sp"
                android:textColor="#1F1F1F"
                android:paddingEnd="12dp" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="编辑资料"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1F1F1F" />
            <TextView
                android:id="@+id/tvSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="保存"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#2F80ED" />
        </LinearLayout>

        <!-- 头像 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/layoutAvatar"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:background="?android:attr/selectableItemBackground">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="头像"
                    android:textSize="16sp" android:textColor="#1F1F1F"/>
                <ImageView
                    android:id="@+id/ivAvatarPreview"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_auth_logo"
                    android:layout_marginEnd="8dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="#C7C7CC"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="#E5E5EA" android:layout_marginStart="20dp"/>

            <!-- 昵称 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="昵称" android:textSize="16sp" android:textColor="#1F1F1F"/>
                <EditText
                    android:id="@+id/etNickname"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:textSize="15sp"
                    android:textColor="#1F1F1F"
                    android:hint="请输入昵称"
                    android:textColorHint="#C7C7CC"
                    android:gravity="center_vertical|end"
                    android:imeOptions="actionDone"
                    android:singleLine="true" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="点击头像可从相册选择图片"
            android:textSize="12sp"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:paddingTop="8dp" />

    </LinearLayout>
</ScrollView>
