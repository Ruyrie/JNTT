<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="72dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_auth_logo"
                android:text="头条"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="吉农头条"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1F1F1F"
                android:layout_marginStart="10dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="你好，"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#1F1F1F" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="欢迎回来"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#1F1F1F"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="登录账号，发现更多新鲜资讯"
            android:textSize="14sp"
            android:textColor="#8A8A8A"
            android:layout_marginBottom="40dp" />

        <EditText
            android:id="@+id/etLoginUsername"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_auth_input"
            android:hint="请输入用户名"
            android:textColorHint="#B5B5B5"
            android:textColor="#1F1F1F"
            android:textSize="15sp"
            android:inputType="text"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="14dp" />

        <EditText
            android:id="@+id/etLoginPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_auth_input"
            android:hint="请输入密码"
            android:textColorHint="#B5B5B5"
            android:textColor="#1F1F1F"
            android:textSize="15sp"
            android:inputType="textPassword"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="28dp" />

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_auth_button"
            android:text="登 录"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:stateListAnimator="@null"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="48dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="还没有账号？"
                android:textSize="13sp"
                android:textColor="#8A8A8A" />

            <TextView
                android:id="@+id/tvGoRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="立即注册"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#F04142"
                android:padding="4dp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="登录即表示同意《用户协议》和《隐私政策》"
            android:textSize="11sp"
            android:textColor="#B5B5B5"
            android:gravity="center"
            android:layout_marginTop="32dp" />

    </LinearLayout>
</ScrollView>
