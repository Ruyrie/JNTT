<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.JNTT" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="android:windowAnimationStyle">@style/IosWindowAnimation</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:fitsSystemWindows">true</item>
    </style>

    <style name="Theme.JNTT" parent="Base.Theme.JNTT" />

    <!-- iOS 风格 Activity 转场动画 -->
    <style name="IosWindowAnimation" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/ios_slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/ios_slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/ios_slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/ios_slide_out_right</item>
    </style>

    <!-- 我的页面菜单项样式 -->
    <style name="MineMenuStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">18dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:background">?android:attr/selectableItemBackground</item>
    </style>

    <!-- 设置页面条目样式 -->
    <style name="SettingsItemStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">18dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:background">?android:attr/selectableItemBackground</item>
    </style>

    <!-- 分隔线 -->
    <style name="Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">#EEEEEE</item>
    </style>

</resources>
